# ============================================================
# hbscloud 配置（请复制为 .env 后填入真实值，并加入 .gitignore）
# ============================================================

# 你的 hbscloud API Key
HBS_API_KEY=sk-your-key-here

# hbscloud 兼容 OpenAI 的 base url
HBS_BASE_URL=https://model.hbscloud.com.cn/v1

# hbscloud 上实际可用的模型（先用 burntoken --models 查询）
HBS_MODEL=gpt-3.5-turbo

# ============================================================
# 成本核算（可选）
# 单位：每 1k token 的价格（CNY 或 USD 自定）
# 留 0 则不计算
# ============================================================
HBS_PRICE_PROMPT=0
HBS_PRICE_COMPLETION=0

# hbscloud 证书链签发对象是 *.hbslft.com，需要关闭 SSL 验证才能通
HBS_VERIFY=false
